{
  "name": "youtubetranslator",
  "version": "1.0.0",
  "description": "",
  "main": "Electron/main/index.js",
  "scripts": {
    "start": "chcp 65001 > nul && electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.youtubetranslator.app",
    "productName": "YoutubeTranslator",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable"
    },
    "extraResources": [
      {
        "from": "Python",
        "to": "Python",
        "filter": [
          "**/*",
          "!.venv/Include/**",
          "!.venv/share/**"
        ]
      },
      {
        "from": "setconfig",
        "to": "setconfig",
        "filter": [
          "**/*",
          "!models/**"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "jukgol",
        "repo": "YoutubeTranslator"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jukgol/YoutubeTranslator.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jukgol/YoutubeTranslator/issues"
  },
  "homepage": "https://github.com/jukgol/YoutubeTranslator#readme",
  "devDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "electron-updater": "^6.8.3",
    "yt-dlp-exec": "^1.0.2"
  }
}
